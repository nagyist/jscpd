{
  "name": "service-api",
  "version": "1.0.0",
  "description": "REST API service for the platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest --coverage --runInBand",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "winston": "^3.10.0",
    "joi": "^17.9.2",
    "axios": "^1.5.0",
    "pg": "^8.11.3",
    "redis": "^4.6.8"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "@types/express": "^4.17.18",
    "@types/node": "^20.6.0",
    "@types/cors": "^2.8.14",
    "@types/morgan": "^1.9.5",
    "@types/pg": "^8.10.3",
    "jest": "^29.6.4",
    "ts-jest": "^29.1.1",
    "@types/jest": "^29.5.5",
    "eslint": "^8.49.0",
    "prettier": "^3.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
