{
  // Application configuration - JSON5 format with comments
  name: "my-application",
  version: "2.1.0",
  description: "A sample application configuration",

  server: {
    host: "0.0.0.0",
    port: 3000,
    ssl: false,
    timeout: 30000, // milliseconds

    // Database connection settings
    database: {
      host: "db.example.com",
      port: 5432,
      name: "appdb",
      poolMin: 2,
      poolMax: 20,
      idleTimeout: 10000,
      connectionTimeout: 5000,
    },

    // Redis cache settings
    cache: {
      host: "cache.example.com",
      port: 6379,
      ttl: 3600, // 1 hour
      maxMemory: "512mb",
    },
  },

  auth: {
    jwtSecret: "change-me-in-production",
    jwtExpiry: "7d",
    refreshExpiry: "30d",
    bcryptRounds: 12,
  },

  // Feature flags
  features: {
    darkMode: true,
    betaFeatures: false,
    analytics: true,
    rateLimit: {
      enabled: true,
      maxRequests: 100,
      windowMs: 60000, // 1 minute
    },
  },
}
