+const retryOnFailure = async (maxAttempts, fn) => {
+  let attempt = 0;
+  while (attempt < maxAttempts) {
+    try {
+      return await fn();
+    } catch (err) {
+      attempt++;
+      if (attempt >= maxAttempts) throw err;
+    }
+  }
+};
